{
    "name": "react-tailwind-ui",
    "type": "module",
    "version": "1.0.0",
    "main": "dev/index.js",
    "module": "dev/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "rollup -c",
        "dev": "rollup -c -w",
        "dev:tsc": "tsc --watch -p tsconfig.dev.json",
